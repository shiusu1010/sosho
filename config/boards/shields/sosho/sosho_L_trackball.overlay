#include "sosho_L.dtsi"

/* 物理的な通信バス（SPI）を有効化 */
&spi0 {
    status = "okay";
};

/* 物理的なトラックボール（PMW3610）の動作設定 */
&trackball {
    status = "okay";
};

/* ▼ 最新ZMK仕様：トラックボールの入力を電波に乗せるための翻訳機 ▼ */
/ {
    trackball_listener {
        compatible = "zmk,input-listener";
        device = <&trackball>;
    };
};