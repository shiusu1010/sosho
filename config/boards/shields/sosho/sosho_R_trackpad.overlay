#include "sosho_R.dtsi"

&spi0 {
    status = "okay";
};

&glidepoint {
    status = "okay";
    invert-y;
};

/* センサーのデータをSplit（送信）チャネルに流し込みます */
/* reg = <0> にすることで、ドングルの glidepoint_split@0 と完全に紐付きます */
&glidepoint_split {
    status = "okay";
    device = <&glidepoint>;
    reg = <0>;
};